{
  "name": "@getsquish/squish",
  "version": "0.3.1",
  "mcpName": "io.github.getsquish/squish",
  "description": "Give AI random access to video: timestamped contact sheets + zoom into any start/end range, on-device. CLI + MCP server (getsquish.app).",
  "keywords": [
    "video",
    "contact-sheet",
    "vision",
    "ai",
    "agent",
    "mcp",
    "ffmpeg",
    "timestamp",
    "frames",
    "video-analysis",
    "video-retrieval",
    "multimodal"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "squish": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getsquish/squish.git"
  },
  "homepage": "https://getsquish.app",
  "bugs": "https://github.com/getsquish/squish/issues",
  "scripts": {
    "squish": "tsx src/main.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "tsc --noEmit",
    "build": "tsup",
    "prepack": "npm run build",
    "mcp": "tsx src/mcp.ts",
    "e2e": "tsx tests/mcp.e2e.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^1.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
